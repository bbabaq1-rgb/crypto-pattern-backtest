# .streamlit/secrets.toml.example
# Streamlit Cloud → Settings → Secrets 에 아래 내용을 그대로 붙여넣고 값만 바꾸세요.
# 이 파일(.example)은 커밋해도 안전합니다. 실제 secrets.toml은 절대 커밋하지 마세요.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL       = "https://xxxxxxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY  = "eyJhbGci..."   # Supabase → Settings → API → anon public
# SUPABASE_SERVICE_KEY = "eyJhbGci..."  # 쓰기 권한이 필요한 경우만 추가

# ── OKX 선물 (실계좌 잔고 표시 + 수동 청산 버튼) ───────────────────────────────
# OKX → API → Create API Key (Futures 거래 권한, IP 제한 없음 또는 Streamlit IP 허용)
OKX_KEY        = "your-api-key"
OKX_SECRET     = "your-api-secret"
OKX_PASSPHRASE = "your-passphrase"
