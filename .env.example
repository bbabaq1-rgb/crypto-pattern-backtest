# .env.example — 이 파일을 .env로 복사하고 실제 값을 채우세요.
# .env는 .gitignore에 있어 커밋되지 않습니다. 키를 코드에 절대 넣지 마세요.
#
# 값 위치: Supabase > Project Settings > Data API
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon public key>
SUPABASE_SERVICE_KEY=<service_role secret key>

# 비트겟 데모 API (없으면 시뮬레이션 모드)
BITGET_DEMO_KEY=
BITGET_DEMO_SECRET=
BITGET_DEMO_PASSPHRASE=
